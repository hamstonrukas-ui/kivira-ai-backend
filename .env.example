# ═══════════════════════════════════════════════════════════
# KiviraAI Backend — Variables d'environnement
# ═══════════════════════════════════════════════════════════
# Copiez ce fichier en ".env" pour le développement local.
# Sur Render, configurez ces mêmes variables dans le dashboard
# (Environment > Add Environment Variable). NE JAMAIS commit le .env réel.

# Clé API Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-votre-cle-ici

# Modèle utilisé pour la traduction (Haiku = le moins cher, recommandé)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ───────────────────────────────────────────────────────────
# Connexion PostgreSQL — MÊME base que le backend d'authentification
# (Render PostgreSQL). Copiez l'Internal Database URL exacte utilisée
# pour le backend principal (kivirafacile-api).
# ───────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@dpg-xxxxx.frankfurt-postgres.render.com/kivirafacile

# Secret utilisé pour vérifier les tokens JWT émis par le système d'auth
# DOIT être EXACTEMENT le même secret que JWT_SECRET du backend principal
# (server.js), car les tokens sont signés avec { uuid, email }.
JWT_SECRET=le-meme-secret-que-votre-backend-auth-principal

# Nombre de traductions gratuites à vie par utilisateur
FREE_TRANSLATION_QUOTA=3

# Plafond quotidien anti-abus pour les utilisateurs PREMIUM uniquement
# (les utilisateurs gratuits n'atteignent jamais ce chiffre, plafonnés à 3 à vie)
DAILY_TRANSLATION_LIMIT=20

# Port du serveur (Render le définit automatiquement, 3000 pour le local)
PORT=3000

# Origine autorisée pour CORS (votre domaine front-end en production)
ALLOWED_ORIGIN=https://votre-app.vercel.app

# Environnement (active SSL pour PostgreSQL en production)
NODE_ENV=development
